generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum HttpMethod {
  GET
  POST
  PUT
  PATCH
  DELETE
  HEAD
  OPTIONS
}

model Task {
  id        Int      @id @default(autoincrement())
  apiKey    String   @unique
  title     String
  completed Boolean  @default(false)
  createdAt DateTime @default(now())

  userId Int
  user   User @relation(fields: [userId], references: [id])
}

model User {
  id            Int            @id @default(autoincrement())
  name          String
  email         String         @unique
  password      String
  createdAt     DateTime       @default(now())

  tasks         Task[]
  monitoredAPIs MonitoredAPI[]
  apiKeys       ApiKey[]
}

model ApiCheck {
  id           Int      @id @default(autoincrement())
  apiId        Int
  api          MonitoredAPI @relation(fields: [apiId], references: [id])
  status       String
  responseTime Int?
  createdAt    DateTime @default(now())
}

model MonitoredAPI {
  id         Int        @id @default(autoincrement())
  name       String
  url        String
  method     HttpMethod @default(GET)
  headers    Json?
  body       Json?
  status     String     @default("unknown")

  userId Int
  user   User @relation(fields: [userId], references: [id])

  apiChecks ApiCheck[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ApiKey {
  id          Int       @id @default(autoincrement())
  name        String
  key         String    @unique
  isActive    Boolean   @default(true)

  userId      Int
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())
}